record(ai, "$(P)readback") {
    field(DESC, "Legacy sidecar readback")
    field(DTYP, "Soft Channel")
    field(VAL, "1.234")
    field(EGU, "a.u.")
    field(PREC, "3")
    field(LOPR, "0")
    field(HOPR, "10")
}

record(ao, "$(P)setpoint") {
    field(DESC, "Legacy sidecar writable setpoint")
    field(DTYP, "Soft Channel")
    field(VAL, "0")
    field(EGU, "a.u.")
    field(PREC, "3")
    field(LOPR, "0")
    field(HOPR, "10")
}

record(longin, "$(P)counter") {
    field(DESC, "Legacy sidecar counter")
    field(DTYP, "Soft Channel")
    field(VAL, "42")
}
