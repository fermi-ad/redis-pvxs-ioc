### Setting dummys
record(ao,"$(ndev):cdummy") {
    field(DESC,"Dummy PV for Control")
    field(PINI,"YES")
    field(VAL, "0")
    field(SCAN,"Passive")
}
record(ao,"$(ndev):sdummy") {
    field(DESC,"Dummy PV for Setting")
    field(PINI,"YES")
    field(VAL, "0")
    field(SCAN,"Passive")
}
